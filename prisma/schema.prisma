generator client {
  provider = "prisma-client"
  output   = "../PrismaApp/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Region {
  id            String   @id @default(cuid()) // Уникальный идентификатор региона
  subdomain     String   @unique // Поддомен
  city          String // Название города
  preposutional String // Название города в склонении
  address       String // Адрес офиса
  email         String // Адрес электронной почты
  metro         String // Ближайшее метро
  map           String // Карта
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("regions")
}

model PostView {
  id          String   @id @default(cuid())
  slug        String   @unique
  views       Int      @default(0)
  lastUpdated DateTime @default(now()) @updatedAt

  @@map("post_views")
}
